{
  "rules": {
    ".read": false,
    ".write": false,
    "labs": {
      ".read": "auth != null",
      "$room": {
        ".write": "auth.token.teacher === true",
        "pcs": {
          "$pc": {
            ".write": "auth.token.teacher === true",
            "online": { ".write": "auth != null" },
            "lastSeen": { ".write": "auth != null" },
            "hostname": { ".write": "auth != null" }
          }
        }
      }
    }
  }
}
